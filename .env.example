# =============================================================================
# 钉钉考勤机器人 — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入真实值，所有设置都从这里读

# --- 钉钉应用凭证 ---
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# ==================== 考勤组 & 组织架构 ====================
ATTENDANCE_GROUP_ID=
OP_USER_ID=
SUB_DEPT_ID=

# ==================== 运行模式 ====================
ENABLE_CALLBACK_SERVER=stream
# HOST=0.0.0.0
# PORT=8000

# ==================== 阈值通知 ====================
# {"week":3,"month":9} 每周超3次/每月超9次时提醒
# NOTIFY_THRESHOLDS={"week":3}

# ==================== 定时推送目标（唯一配置）====================
# NOTIFICATION_TARGETS=[
#   {"type":"group","webhook":"https://...","period":"week","schedule":"6 12:00"}
# ]

# ==================== Mock 模式 ====================
MOCK_MODE=true
