# =============================================================================
# 钉钉考勤机器人 — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入真实值，所有设置都从这里读

# --- 钉钉应用凭证 ---
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# ==================== 考勤组 & 组织架构 ====================
ATTENDANCE_GROUP_ID=
OP_USER_ID=
SUB_DEPT_ID=

# ==================== 运行模式 ====================
ENABLE_CALLBACK_SERVER=stream
# HOST=0.0.0.0
# PORT=8000

# ==================== 阈值通知（编辑 thresholds.json）====================

# ==================== 定时推送目标（编辑 targets.json）====================
# 编辑 targets.json 文件配置推送目标，参考 targets.example.json

# ==================== Mock 模式 ====================
MOCK_MODE=true
