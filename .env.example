# =============================================================================
# 钉钉考勤机器人 — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入真实值，所有设置都从这里读

# --- 钉钉应用凭证 ---
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# --- 群机器人 Webhook ---
ROBOT_WEBHOOK_URL=
ROBOT_SECRET=

# ==================== 定时任务 ====================
SCHEDULE_DAY_OF_WEEK=6
SCHEDULE_HOUR=12
SCHEDULE_MINUTE=0
DEFAULT_PERIOD=week
DEFAULT_SEND_TYPE=group

# ==================== 考勤组 & 组织架构 ====================
ATTENDANCE_GROUP_ID=
OP_USER_ID=
SUB_DEPT_ID=

# ==================== 运行模式 ====================
# stream:  Stream 模式（默认推荐，WebSocket 长连接，不占端口）
# http:    HTTP 回调模式（传统方式，需开放端口）
# false:   仅定时推送，不接收群消息
ENABLE_CALLBACK_SERVER=stream
# HOST=0.0.0.0
# PORT=8000

# ==================== Mock 模式 ====================
MOCK_MODE=true
